# ── StreamShōgun Backend — Environment Variables ───────────────────────

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stream_shogun?schema=public

# JWT — use a strong random secret (min 32 chars)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated origins
CORS_ORIGIN=http://localhost:5173

# Stripe (future — leave blank for now)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
