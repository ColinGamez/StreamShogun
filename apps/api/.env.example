# ── Server ─────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0

# ── Database ───────────────────────────────────────────
# Local PG: postgresql://postgres:<password>@localhost:5433/streamshogun?schema=public
# Docker:   postgresql://shogun:shogun@localhost:5432/streamshogun?schema=public
DATABASE_URL="postgresql://postgres:changeme@localhost:5433/streamshogun?schema=public"

# ── JWT ────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ── CORS ───────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ── Observability (optional) ───────────────────────────
# SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# ── Admin (optional — enables /v1/admin endpoints) ────
# ADMIN_KEY="your-secret-admin-key-min-16-chars"

# ── Stripe (optional — enables /v1/billing) ────────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_ID="price_..."
