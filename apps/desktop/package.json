{
  "name": "@stream-shogun/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs && electron-builder --config electron-builder.yml",
    "build:win": "node scripts/build.mjs && electron-builder --config electron-builder.yml --win",
    "build:mac": "node scripts/build.mjs && electron-builder --config electron-builder.yml --mac",
    "build:linux": "node scripts/build.mjs && electron-builder --config electron-builder.yml --linux",
    "build:unpackaged": "node scripts/build.mjs",
    "clean": "node -e \"const fs=require('fs');['dist','out','release'].forEach(d=>{fs.rmSync(d,{recursive:true,force:true})})\""
  },
  "dependencies": {
    "@stream-shogun/core": "workspace:*",
    "@stream-shogun/shared": "workspace:*",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.4.0"
  }
}
